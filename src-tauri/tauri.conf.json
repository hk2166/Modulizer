{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoiceForge",
  "version": "0.1.0",
  "identifier": "com.voiceforge.app",
  "build": {
    "beforeDevCommand": "npm run frontend:dev",
    "beforeBuildCommand": "npm run frontend:build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VoiceForge",
        "width": 1100,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/voiceforge-sidecar"
    ]
  }
}
