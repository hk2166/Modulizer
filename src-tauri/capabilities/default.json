{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "log:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/voiceforge-sidecar",
          "sidecar": true
        }
      ]
    }
  ]
}
